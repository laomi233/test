二、Sling Model（可用于 React SPA JSON）
@Model(
  adaptables = SlingHttpServletRequest.class,
  adapters = ComponentExporter.class,
  resourceType = "project/components/insight-loadmore"
)
public class InsightLoadMoreModel implements ComponentExporter {

    @Inject @Optional
    private String folderPath;

    @Inject @Optional
    private int initialLoad = 9;

    @Inject @Optional
    private int loadMoreCount = 9;

    @Inject
    private ResourceResolver resolver;

    public List<InsightItem> getItems() {

        List<InsightItem> items = new ArrayList<>();

        if(folderPath == null) return items;

        Resource folder = resolver.getResource(folderPath);

        if(folder == null) return items;

        for(Resource child : folder.getChildren()) {

            ValueMap vm = child.getChild("jcr:content/data/master").getValueMap();

            InsightItem item = new InsightItem();
            item.setTitle(vm.get("title", String.class));
            item.setDescription(vm.get("description", String.class));
            item.setLink(vm.get("link", String.class));
            item.setImage(vm.get("image", String.class));
            items.add(item);
        }

        return items;
    }

    public int getInitialLoad() { return initialLoad; }
    public int getLoadMoreCount() { return loadMoreCount; }

    @Override
    public String getExportedType() {
        return "project/components/insight-loadmore";
    }
}
