1️⃣ InsightLoadMore.js
import React, {useState} from "react";
import CardItem from "./CardItem";
import "./InsightLoadMore.scss";

const InsightLoadMore = ({cqModel}) => {

 const items = cqModel.items || [];

 const initialLoad = cqModel.initialLoad || 9;
 const loadMoreCount = cqModel.loadMoreCount || 9;

 const [visibleCount, setVisibleCount] = useState(initialLoad);

 const visibleItems = items.slice(0, visibleCount);

 const handleLoadMore = () => {
   setVisibleCount(prev => Math.min(prev + loadMoreCount, items.length));
 };

 return (
   <div className="insight-loadmore">

     <div className="insight-grid">
       {visibleItems.map((item,i) => (
         <CardItem key={i} item={item} />
       ))}
     </div>

     {visibleCount < items.length && (
       <div className="load-more">
         <button onClick={handleLoadMore}>
           Load More
         </button>
       </div>
     )}

   </div>
 );
};

export default InsightLoadMore;
